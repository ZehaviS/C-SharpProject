    public void SearchSaleForProduct(ProductInOrder productInOrder, bool isPreferedCustomer)
    {
        try
        {
            var now = DateTime.Now;

            var relevantSales = _dal.sale.ReadAll()
                .Where(sale => sale != null
                    && sale.ProductId == productInOrder.ProductId
                    && (sale.DateStart == null || sale.DateStart <= now)
                    && (sale.DateEnd == null || sale.DateEnd >= now)
                    && productInOrder.Count >= sale.ProductsCountToSale
                    && (isPreferedCustomer || !sale.OnlyClubCustomers))
                .OrderBy(sale => sale.PriceAfterSale)
                .Select(sale => new SaleInProduct
                {
                    SaleId = sale.SaleId,
                    PriceAfterSale = sale.PriceAfterSale,
                    ProductsCountToSale = sale.ProductsCountToSale,                    OnlyClubCustomers = sale.OnlyClubCustomers,
                    DateStart = sale.DateStart,
                    DateEnd = sale.DateEnd
                })
                .ToList();

            productInOrder.Sales = relevantSales;
        }
        catch (Exception ex)
        {
            // Wrap and rethrow - BL-specific exceptions can be added in BO.Exceptions.cs
            throw new Exception("Error while searching sales for product", ex);
        }
    }

